# Use official Node.js image
FROM node:20-alpine

# Set working directory
WORKDIR /app

# Copy package.json & package-lock.json
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy the rest of the frontend source
COPY . .

# Build Next.js app
RUN npm run build

# Expose default Next.js port
EXPOSE 3000

# Start the app (SSR)
CMD ["npm", "run", "start"]